{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/slot-autofill-profiles.schema.json",
  "title": "Slot Autofill Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/profile"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "display_name",
        "status",
        "slot_schema_id",
        "enabled",
        "react_call",
        "run_order",
        "input_mapping",
        "output_mapping"
      ],
      "properties": {
        "profile_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "disabled"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 1000
        },
        "slot_schema_id": {
          "$ref": "#/$defs/id"
        },
        "enabled": {
          "type": "boolean"
        },
        "react_call": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "run_order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "accept_policy": {
          "type": "string",
          "enum": [
            "single_result",
            "always"
          ]
        },
        "input_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(slot|case|context|constant|secret):.+$"
          }
        },
        "output_mapping": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/output_mapping"
          }
        },
        "on_no_result": {
          "type": "string",
          "enum": [
            "continue",
            "ask_client",
            "operator_handoff"
          ]
        },
        "on_ambiguous_result": {
          "type": "string",
          "enum": [
            "continue",
            "ask_client",
            "operator_handoff"
          ]
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "output_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_field",
        "target_slot"
      ],
      "properties": {
        "result_field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "target_slot": {
          "$ref": "#/$defs/id"
        },
        "required_for_success": {
          "type": "boolean"
        }
      }
    }
  }
}
