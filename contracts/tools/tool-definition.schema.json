{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/tools/tool-definition.schema.json",
  "title": "Tool Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool_name",
    "action_type",
    "description",
    "endpoint_bindings",
    "parameters_schema",
    "result_schema",
    "contract_version",
    "contract_status",
    "policy"
  ],
  "properties": {
    "tool_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "action_type": {
      "type": "string",
      "enum": [
        "read_only",
        "action"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "endpoint_bindings": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "#/$defs/endpoint_binding"
      }
    },
    "parameters_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "result_schema": {
      "type": "object",
      "additionalProperties": true
    },
    "contract_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "contract_status": {
      "type": "string",
      "enum": [
        "draft",
        "valid",
        "broken",
        "deprecated"
      ]
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "endpoint_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "endpoint_id",
        "operation_id"
      ],
      "properties": {
        "endpoint_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "operation_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "parameter_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(react|constant|secret):.+$"
          }
        },
        "result_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_timeout_seconds",
        "retry",
        "approval_required_hint",
        "auto_execution_eligible",
        "max_risk_level"
      ],
      "properties": {
        "default_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_attempts",
            "backoff_seconds"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5
            },
            "backoff_seconds": {
              "type": "number",
              "minimum": 0,
              "maximum": 30
            }
          }
        },
        "approval_required_hint": {
          "type": "boolean"
        },
        "auto_execution_eligible": {
          "type": "boolean"
        },
        "max_risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      }
    }
  }
}
