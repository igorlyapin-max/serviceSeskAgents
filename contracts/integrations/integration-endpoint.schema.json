{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/integrations/integration-endpoint.schema.json",
  "title": "Integration Endpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "endpoint_id",
    "adapter_type",
    "enabled",
    "operations"
  ],
  "properties": {
    "endpoint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "adapter_type": {
      "type": "string",
      "enum": [
        "mock",
        "n8n_webhook",
        "direct_http",
        "queue"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "enabled": {
      "type": "boolean"
    },
    "disabled_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "base_url_env": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "auth": {
      "$ref": "#/$defs/auth"
    },
    "operations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/operation"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "header_token",
            "bearer_token"
          ]
        },
        "header_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "token_env": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "description",
        "method",
        "path",
        "request_schema",
        "response_schema",
        "contract_version",
        "contract_status",
        "timeout_seconds"
      ],
      "properties": {
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "method": {
          "type": "string",
          "enum": [
            "GET",
            "POST"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "request_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "response_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "contract_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "contract_status": {
          "type": "string",
          "enum": [
            "draft",
            "valid",
            "broken",
            "deprecated"
          ]
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "mock_output": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
