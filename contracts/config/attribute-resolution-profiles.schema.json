{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicedeskagents.local/contracts/config/attribute-resolution-profiles.schema.json",
  "title": "Attribute Resolution Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id",
          "display_name",
          "status",
          "description",
          "target_slot_id",
          "input_slots",
          "enrichment_steps",
          "output_slots_order",
          "llm_resolution_script",
          "human_resolution_policy",
          "max_attempts",
          "audit_required",
          "log_required"
        ],
        "properties": {
          "profile_id": {
            "$ref": "#/$defs/id"
          },
          "display_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "active",
              "planned",
              "disabled"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "target_slot_id": {
            "$ref": "#/$defs/id"
          },
          "input_slots": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/input_slot"
            }
          },
          "enrichment_steps": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/enrichment_step"
            }
          },
          "output_slots_order": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/output_slot_rule"
            }
          },
          "llm_resolution_script": {
            "$ref": "#/$defs/llm_resolution_script"
          },
          "human_resolution_policy": {
            "$ref": "#/$defs/human_resolution_policy"
          },
          "fallback": {
            "$ref": "#/$defs/fallback"
          },
          "confidence_threshold": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "confidence_thresholds": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "auto_fill": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "clarification": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "operator_handoff": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "audit_required": {
            "type": "boolean"
          },
          "log_required": {
            "type": "boolean"
          },
          "extensions": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9_.-]*$"
    },
    "id_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "source_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "input_slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "required_for_operation",
        "can_ask_user"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/id"
        },
        "required_for_operation": {
          "type": "boolean"
        },
        "can_ask_user": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "maxLength": 600
        }
      }
    },
    "enrichment_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_name",
        "react_call",
        "parameter_mapping",
        "result_entity_name",
        "result_entity_description",
        "on_error"
      ],
      "properties": {
        "step_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "react_call": {
          "$ref": "#/$defs/id"
        },
        "result_entity_name": {
          "$ref": "#/$defs/id"
        },
        "result_entity_description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "parameter_mapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^(slot|output|entity|constant|secret):.+$"
          }
        },
        "result_fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/result_field"
          }
        },
        "on_error": {
          "type": "string",
          "enum": [
            "continue_to_llm",
            "stop_and_ask_client",
            "escalate_operator"
          ]
        }
      }
    },
    "result_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_id",
        "display_name",
        "field_type"
      ],
      "properties": {
        "field_id": {
          "$ref": "#/$defs/id"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "field_type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "object",
            "array",
            "unknown"
          ]
        },
        "description": {
          "type": "string",
          "maxLength": 600
        }
      }
    },
    "output_slot_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "order",
        "required_for_success",
        "source_hint",
        "fallback"
      ],
      "properties": {
        "slot_id": {
          "$ref": "#/$defs/id"
        },
        "order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "required_for_success": {
          "type": "boolean"
        },
        "source_hint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "fallback": {
          "type": "string",
          "enum": [
            "ask_clarification",
            "operator_handoff",
            "leave_empty"
          ]
        }
      }
    },
    "llm_resolution_script": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_text",
        "response_contract"
      ],
      "properties": {
        "script_text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "response_contract": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "human_resolution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clarification_question",
        "clarification_slots",
        "handoff_package",
        "handoff_action",
        "fallback_action"
      ],
      "properties": {
        "clarification_question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "clarification_slots": {
          "$ref": "#/$defs/id_list"
        },
        "handoff_package": {
          "$ref": "#/$defs/id_list"
        },
        "handoff_action": {
          "type": "string",
          "enum": [
            "operator_handoff",
            "escalate",
            "debug_stop",
            "leave_empty"
          ]
        },
        "fallback_action": {
          "type": "string",
          "enum": [
            "ask_user",
            "operator_handoff",
            "escalate",
            "leave_empty"
          ]
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "ask_user",
            "operator_handoff",
            "escalate",
            "leave_empty"
          ]
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        }
      }
    }
  }
}
